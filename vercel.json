{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/success-stories", "destination": "/impact", "permanent": true },
    { "source": "/success-stories/:slug", "destination": "/impact/:slug", "permanent": true }
  ],
  "crons": [
    { "path": "/api/keepalive", "schedule": "0 6 */5 * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
